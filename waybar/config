{
    "layer": "top",
    "position": "top",
    "height": 50,
    "margin-top": 0,
    "modules-left": ["custom/launcher", "hyprland/workspaces", "mpris", "cava"],
    "modules-center": ["clock"],
    "modules-right": ["hyprland/language", "pulseaudio", "tray", "custom/power"],
    "custom/launcher": { "format": "󰣇" },
    "hyprland/workspaces": { "format": "{name}" },
    "mpris": { "format": "  {title}", "max-length": 25 },
    "cava": {
        "framerate": 30,
        "autosens": 1,
        "bars": 12,
        "lower_cutoff_freq": 50,
        "higher_cutoff_freq": 10000,
        "method": "pulse",
        "source": "auto",
        "stereo": true,
        "bar_delimiter": 0,
        "noise_reduction": 0.77,
        "input_delay": 2,
        "format-icons" : [" ", "▂", "▃", "▄", "▅", "▆", "▇", "█" ]
    },
    "clock": { "format": "{:%H:%M}" },
    "hyprland/language": { "format": "{short}" },
    "pulseaudio": { "format": " {volume}%" },
    "tray": { "icon-size": 18, "spacing": 10 },
    "custom/power": { "format": "" }
}
